# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.idea
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# one-off test scripts (install deps locally; do not commit)
tmp-upload-templates/node_modules/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
release/
# vercel
.vercel
electron/standalone

# typescript
*.tsbuildinfo
next-env.d.ts

templates/**/*

# 2. Ignore everything inside the subfolders
templates/appointments/*
templates/roles/*
templates/standard-models/*

!templates/appointments/.gitkeep
!templates/roles/.gitkeep
!templates/standard-models/.gitkeep

