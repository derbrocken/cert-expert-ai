generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  slug          String   @id
  displayName   String
  active        Boolean  @default(true)
  employeeFiles EmployeeFile[]
  exportSettings CompanyExportSettings?
  documents     CompanyDocumentItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanyExportSettings {
  companySlug    String  @id
  company        Company @relation(fields: [companySlug], references: [slug], onDelete: Cascade)
  companyName    String  @default("")
  companyEmail   String  @default("")
  companyAddress String  @default("")
  logoStorageKey String?
  documentVersion String?
  documentDate   String?
  createdBy      String?
  approvedBy     String?
  updatedAt      DateTime @updatedAt
}

model EmployeeFile {
  id                         String   @id
  companySlug                String
  company                    Company  @relation(fields: [companySlug], references: [slug], onDelete: Cascade)
  fullName                   String
  birthday                   String   @default("")
  startDate                  String   @default("")
  roleId                     String   @default("")
  appointmentIds             Json     @default("[]")
  selectedRoleDocIds         Json     @default("[]")
  selectedAppointmentDocIds  Json     @default("[]")
  roleClasses                Json?
  roleClass                  String?
  roleType                   String?
  employmentType             String?
  qualification              String?
  trainingHours              String?
  guardIDNumber              String?
  employeeIDNumber           String?
  useGuardAsEmployeeId       Boolean?
  // Lane K — Geschlecht (minimale, nullable PII). Einziger Zweck: bedingtes
  // Mutterschutz-Hinweis-Overlay (CL-77, MuSchG, „fachlich prüfen") für
  // weibliche MA. String ("weiblich"/"maennlich"/"divers"). Nullable/additiv
  // (kein @default → P2023-sicher). Keine Engine-/Auto-Status-Wirkung (EC-10).
  gender                     String?
  zusatzBewachungNiveau      String?
  sdlScopes                  Json     @default("[]")
  drivesServiceVehicle       Boolean?
  ersteHilfeGueltigBis       String?
  brandschutzGueltigBis      String?
  // M6 (DM6) — Austrittsdatum (Lebenszyklus „inaktiv"). Datums-String wie
  // startDate/ersteHilfeGueltigBis. Nullable/additiv (kein @default →
  // P2023-sicher, kein Breaking für Bestandsakten). Keine Engine-/Auto-Status-
  // Wirkung (EC-10) — reines Stammdatum.
  exitDate                   String?
  // M6 (DM6b) — Datum Erst-Standardunterweisung (CL-75). Datums-String.
  // Nullable/additiv (kein @default → P2023-sicher). Default-Vorschlag = startDate
  // wird in der Maske/Engine über die VORHANDENE Logik defaultErstunterweisungDatum
  // gebildet (keine zweite Default-Quelle). Speist den bestehenden Engine-Input
  // RequirementContext.erstunterweisungDatum.
  erstunterweisungDatum      String?
  weiterbildungIstUE         Int?
  einmaligIstUE              Json?
  trainingPlan               Json?
  // Lane J (A1) — persistierter Bestell-Status (Multiselect, unabhängig vom
  // Dokument). Json-Array von BestellungTyp ("ersthelfer"/"brandschutzhelfer"/
  // "sibe"). Nullable/additiv (kein @default → P2023-sicher). Fehlt das Feld auf
  // Bestandsakten, leitet die Read-Normalisierung tolerant aus `appointmentIds`
  // ab (Legacy-Backfill). KEINE Auto-Status-Wirkung (EC-10).
  bestelltAls                Json?
  // Lane J (A1) — optionale, nicht blockierende Verknüpfung Bestellung↔Schulung.
  // Json-Map BestellungTyp → evidenceId/refId (Schulungs-Nachweis). Nullable;
  // KEIN Auto-Status, kein Pflicht-Gate (EC-10).
  bestellungSchulungLink     Json?
  // Lane J (A2) — persistierte Set-Kategorie (Vorlagen-Achse, #D). String
  // ("sicherheitsmitarbeiter"/"fuehrungskraft"/"buerokraft"). Default wird aus
  // Rolle/`roleId` abgeleitet, ist aber überschreibbar. Fehlt das Feld, leitet
  // die Read-Normalisierung aus `roleId` ab (Legacy-Backfill). Nullable/additiv.
  setKategorie               String?
  collectionId               String? // P3b — gewählte Sammlung (Vorauswahl-Quelle)
  // Lane J (A3) — persistiertes Generator-Ausgabedatum je Akte: Json
  // { global?: string; perDocument?: Record<docId,string> }. Ersetzt den
  // bisherigen Session-State. Nullable/additiv (P2023-sicher); reines
  // Ausgabedatum, kein Engine-/Norm-/UE-Eingriff (EC-10).
  generatorDates             Json?
  // P3 / #7 — Prüf-/„geschlossen"-Status je Nachweis (Mark D1). Json-Map
  // evidenceId → { geprueft: boolean; am?: string; von?: string }. Nullable/
  // additiv (kein @default → P2023-sicher). EC-10 (hart): eingehende Nachweise
  // bleiben ungeprüft; erst ein menschlicher „geprüft"-Klick zählt in der Ampel
  // als erfüllt/grün — KEIN Auto-Status. Fehlt das Feld auf Bestandsakten,
  // liest die Read-Normalisierung tolerant „ungeprüft".
  evidenceChecks             Json?
  // M6 (◆-Herkunfts-Badge, aus M3 verschoben) — Liste der Feld-Keys, die beim
  // Tally-Import (`vGNvY0`) tatsächlich befüllt wurden (Json-Array von Strings,
  // z. B. ["fullName","birthday","roleType",…]). Nullable/additiv (kein @default
  // → P2023-sicher). Reine Herkunfts-Markierung für das blaue ◆-Badge; EC-10:
  // „importiert" = UNGEPRÜFT, nie „grün/erledigt". Fehlt das Feld auf Bestands-
  // akten → tolerant als „keine bekannte Tally-Herkunft" gelesen.
  tallyImportedKeys          Json?
  evidenceItems              EvidenceItem[]
  migratedFromLocalStorageAt DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([companySlug])
}

model EvidenceItem {
  id             String       @id @default(cuid())
  employeeFileId String
  employeeFile   EmployeeFile @relation(fields: [employeeFileId], references: [id], onDelete: Cascade)
  evidenceId     String
  fileName       String
  mimeType       String
  storageKey     String
  status         String       @default("unchecked")
  uploadedAt     DateTime

  @@unique([employeeFileId, evidenceId])
}

// P2-B — firmen-ebenes Dokumenten-/Nachweis-Lager (Company-Tally `Y5Zq80`
// FILE_UPLOADs + manueller Upload). Additiv; spiegelt `EvidenceItem` auf
// Company-Ebene (eine Datei pro Katalog-`documentId` pro Firma). EC-10 (hart):
// eingehende Dokumente sind `status:"unchecked"`; erst ein bewusster
// menschlicher „geprüft"-Klick (setzt `checkedAt`/`checkedBy`, status
// "geprueft") wertet das Dokument als geprüft — KEIN Auto-Status. Ein neuer
// Upload (auch via Tally) setzt den Status wieder auf „unchecked" (neue Datei =
// neu prüfen). Katalog = `lib/company-documents-catalog.ts`.
model CompanyDocumentItem {
  id          String    @id @default(cuid())
  companySlug String
  company     Company   @relation(fields: [companySlug], references: [slug], onDelete: Cascade)
  documentId  String
  fileName    String
  mimeType    String
  storageKey  String
  status      String    @default("unchecked")
  checkedBy   String?
  checkedAt   DateTime?
  uploadedAt  DateTime

  @@unique([companySlug, documentId])
}

model MigrationRecord {
  id          String   @id @default(cuid())
  sourceKey   String   @unique
  companySlug String
  completedAt DateTime @default(now())
}

model TallyIntakeRecord {
  responseId   String   @id
  formId       String
  companySlug  String
  employeeIds  Json     @default("[]")
  processedAt  DateTime @default(now())
}

// P3a — editierbare Sammlungen (Framework). Additiv, global (kein Firmen-Scope in P3a).
model DocumentCollection {
  id          String   @id @default(cuid())
  name        String
  description String?
  isSeed      Boolean  @default(false) // die 3 Vordefinierten (read-only)
  seedKey     String?  @unique // "sicherheitsmitarbeiter" | "fuehrungskraft" | "buerokraft"
  items       DocumentCollectionItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DocumentCollectionItem {
  id                  String             @id @default(cuid())
  collectionId        String
  collection          DocumentCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  templateLogicalPath String? // "roles/<slug>/<file>.docx" (null = Seed-Posten ohne Vorlage)
  label               String
  inclusion           String             @default("optional-on") // "mandatory" | "optional-on" | "optional-off"
  dateSource          String             @default("startDate") // "startDate" | "manual"
  clauseId            String?
  templateMissing     Boolean            @default(false)
  sortOrder           Int                @default(0)
}
