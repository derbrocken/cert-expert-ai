generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  slug          String   @id
  displayName   String
  active        Boolean  @default(true)
  employeeFiles EmployeeFile[]
  exportSettings CompanyExportSettings?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanyExportSettings {
  companySlug    String  @id
  company        Company @relation(fields: [companySlug], references: [slug], onDelete: Cascade)
  companyName    String  @default("")
  companyEmail   String  @default("")
  companyAddress String  @default("")
  logoStorageKey String?
  documentVersion String?
  documentDate   String?
  createdBy      String?
  approvedBy     String?
  updatedAt      DateTime @updatedAt
}

model EmployeeFile {
  id                         String   @id
  companySlug                String
  company                    Company  @relation(fields: [companySlug], references: [slug], onDelete: Cascade)
  fullName                   String
  birthday                   String   @default("")
  startDate                  String   @default("")
  roleId                     String   @default("")
  appointmentIds             Json     @default("[]")
  selectedRoleDocIds         Json     @default("[]")
  selectedAppointmentDocIds  Json     @default("[]")
  roleClasses                Json?
  roleClass                  String?
  roleType                   String?
  employmentType             String?
  qualification              String?
  trainingHours              String?
  guardIDNumber              String?
  employeeIDNumber           String?
  useGuardAsEmployeeId       Boolean?
  zusatzBewachungNiveau      String?
  sdlScopes                  Json     @default("[]")
  drivesServiceVehicle       Boolean?
  ersteHilfeGueltigBis       String?
  brandschutzGueltigBis      String?
  weiterbildungIstUE         Int?
  einmaligIstUE              Json?
  trainingPlan               Json?
  // Lane J (A1) — persistierter Bestell-Status (Multiselect, unabhängig vom
  // Dokument). Json-Array von BestellungTyp ("ersthelfer"/"brandschutzhelfer"/
  // "sibe"). Nullable/additiv (kein @default → P2023-sicher). Fehlt das Feld auf
  // Bestandsakten, leitet die Read-Normalisierung tolerant aus `appointmentIds`
  // ab (Legacy-Backfill). KEINE Auto-Status-Wirkung (EC-10).
  bestelltAls                Json?
  // Lane J (A1) — optionale, nicht blockierende Verknüpfung Bestellung↔Schulung.
  // Json-Map BestellungTyp → evidenceId/refId (Schulungs-Nachweis). Nullable;
  // KEIN Auto-Status, kein Pflicht-Gate (EC-10).
  bestellungSchulungLink     Json?
  // Lane J (A2) — persistierte Set-Kategorie (Vorlagen-Achse, #D). String
  // ("sicherheitsmitarbeiter"/"fuehrungskraft"/"buerokraft"). Default wird aus
  // Rolle/`roleId` abgeleitet, ist aber überschreibbar. Fehlt das Feld, leitet
  // die Read-Normalisierung aus `roleId` ab (Legacy-Backfill). Nullable/additiv.
  setKategorie               String?
  // Lane J (A3) — persistiertes Generator-Ausgabedatum je Akte: Json
  // { global?: string; perDocument?: Record<docId,string> }. Ersetzt den
  // bisherigen Session-State. Nullable/additiv (P2023-sicher); reines
  // Ausgabedatum, kein Engine-/Norm-/UE-Eingriff (EC-10).
  generatorDates             Json?
  evidenceItems              EvidenceItem[]
  migratedFromLocalStorageAt DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([companySlug])
}

model EvidenceItem {
  id             String       @id @default(cuid())
  employeeFileId String
  employeeFile   EmployeeFile @relation(fields: [employeeFileId], references: [id], onDelete: Cascade)
  evidenceId     String
  fileName       String
  mimeType       String
  storageKey     String
  status         String       @default("unchecked")
  uploadedAt     DateTime

  @@unique([employeeFileId, evidenceId])
}

model MigrationRecord {
  id          String   @id @default(cuid())
  sourceKey   String   @unique
  companySlug String
  completedAt DateTime @default(now())
}

model TallyIntakeRecord {
  responseId   String   @id
  formId       String
  companySlug  String
  employeeIds  Json     @default("[]")
  processedAt  DateTime @default(now())
}
