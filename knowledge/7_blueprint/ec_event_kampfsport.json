      },
      {
        "id": "missing:medical_service",
        "condition": "medical_service is missing or empty",
        "open_point": "Sanitäts-/Ersthelferregelung fehlt."
      },
      {
        "id": "missing:evacuation_route",
        "condition": "evacuation_route is missing or empty",
