        "open_point": "Einlassbeginn fehlt."
      },
      {
        "id": "missing:event_start_time",
        "condition": "event_start_time is missing or empty",
        "open_point": "Beginn der Veranstaltung fehlt."
      },
      {
        "id": "missing:event_end_time",
        "condition": "event_end_time is missing or empty",
        "open_point": "Ende der Veranstaltung fehlt."
