      {
        "id": "approval_missing",
        "condition": "approved_by is empty",
        "open_point": "Fachliche Freigabe des Einsatzkonzepts ausstehend."
      },
      {
        "id": "requires:upstream_sk_available:upstream_sk_path",
        "condition": "if upstream_sk_available == true then upstream_sk_path must be provided",
        "open_point": "SK-Referenz fehlt, obwohl SK-Upstream aktiviert ist."
