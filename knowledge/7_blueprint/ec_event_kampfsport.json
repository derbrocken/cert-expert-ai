    "critical_triggers": [
      {
        "id": "no_security_staff",
        "condition": "security_staff_count is missing OR security_staff_count <= 0",
        "open_point": "Kräftezahl fehlt oder ist <= 0 — EK nicht einsatzfähig."
      },
      {
        "id": "missing:security_roles",
        "condition": "security_roles is missing or empty",
        "open_point": "Rollen-/Kräfteverteilung fehlt oder ist leer."
      },
      {
        "id": "missing:sections",
        "condition": "sections is missing or empty",
        "open_point": "Einsatzabschnitte fehlen (z. B. Einlass, Zuschauerbereich, Ringbereich)."
      },
      {
        "id": "missing:event_location_address",
        "condition": "event_location_address is missing or empty",
        "open_point": "Vollständige Einsatzadresse fehlt."
      },
      {
        "id": "missing:admission_start_time",
