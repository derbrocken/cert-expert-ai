    "critical_triggers": [
      {
        "id": "venue_exits_missing_or_zero",
        "condition": "venue_exits is missing OR venue_exits == 0",
        "open_point": "Anzahl Notausgänge nicht angegeben — für SK-Fluchtwegeplanung zwingend."
      },
      {
        "id": "overbooking",
        "condition": "expected_attendees > venue_capacity",
        "open_point": "Erwartete Zuschauerzahl überschreitet zulässige Kapazität — Überbelegung im SK klären."
      },
      {
        "id": "approval_missing",
        "condition": "approved_by is empty",
        "open_point": "Freigabe des Sicherheitskonzepts ausstehend."
      },
      {
        "id": "medical_service_missing",
        "condition": "medical_service is empty",
        "open_point": "Sanitätsdienst nicht im Input — Schnittstelle Ring/Sanität im SK nicht belegbar."
      }
    ]
